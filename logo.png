<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 60" width="200" height="60">
  <defs>
    <linearGradient id="roofGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#2563eb;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:1" />
    </linearGradient>
  </defs>
  <!-- House base -->
  <path d="M10 55 L10 35 L30 20 L50 35 L50 55 Z" fill="url(#roofGrad)" opacity="0.9"/>
  <!-- Roof peak -->
  <path d="M5 35 L30 10 L55 35" fill="none" stroke="#2563eb" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
  <!-- Chimney -->
  <rect x="38" y="18" width="6" height="12" fill="#2563eb" opacity="0.7"/>
  <!-- Yakesh text -->
  <text x="65" y="30" font-family="Georgia, serif" font-size="22" font-weight="700" fill="#f1f5f9" letter-spacing="1">YAKESH</text>
  <text x="65" y="48" font-family="Arial, sans-serif" font-size="11" font-weight="600" fill="#94a3b8" letter-spacing="3">ROOFING</text>
</svg>